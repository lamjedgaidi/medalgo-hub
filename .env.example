# Copy to .env for local overrides. .env is gitignored.

# Generate one: python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=change-me

DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Leave unset for SQLite in dev. In prod:
# DATABASE_URL=postgres://user:pass@host:5432/medalgo
DATABASE_URL=
